# JP Bids MCP の Pro APIキー
# JP Bids MCP Pro API key
# Kunci API Pro JP Bids MCP
GATEWAY_CHILD_TOKEN_JP_BIDS=

# freee OAuth トークン（会計余力分析に使用）
# freee OAuth token (used for accounting analysis)
# Token OAuth freee (digunakan untuk analisis akuntansi)
GATEWAY_CHILD_TOKEN_FREEE=

# MoneyForward クラウド会計 OAuth トークン（任意・フォールバック）
# 標準の使い方: MCPクライアントから X-Mcp-Child-Authorization-moneyforward-ca ヘッダで渡す（環境変数不要）
# サーバー固定トークン運用時のみここに設定する
#
# MoneyForward Cloud Accounting OAuth token (optional, fallback)
# Standard usage: pass via X-Mcp-Child-Authorization-moneyforward-ca header from MCP client (no env var needed)
# Set here only when running with a server-side fixed token
#
# Token OAuth MoneyForward Cloud Accounting (opsional, fallback)
# Penggunaan standar: kirim via header X-Mcp-Child-Authorization-moneyforward-ca dari klien MCP (tidak perlu env var)
# Atur di sini hanya saat menjalankan dengan token tetap di sisi server
GATEWAY_CHILD_TOKEN_MONEYFORWARD_CA_OAUTH=

# Gateway Pro APIキー（カンマ区切り）。未設定の場合は全員Proとして扱う。
# Gateway Pro API keys (comma-separated). If unset, all requests are treated as Pro.
# Kunci API Pro Gateway (dipisah koma). Jika tidak disetel, semua permintaan diperlakukan sebagai Pro.
GATEWAY_PRO_API_KEYS=

# JWT 署名シークレット（本番では必須）
# JWT signing secret (required in production)
# Rahasia penandatanganan JWT (wajib di produksi)
GATEWAY_JWT_SECRET=

# 許可するブラウザオリジン（カンマ区切り）。未設定の場合はすべて許可。
# Allowed browser origins (comma-separated). If unset, all origins are allowed.
# Origin browser yang diizinkan (dipisah koma). Jika tidak disetel, semua origin diizinkan.
ALLOWED_ORIGINS=

# ポート番号（デフォルト: 8090）
# Port number (default: 8090)
# Nomor port (default: 8090)
PORT=8090
