{
  "name": "jp-bids-mcp",
  "version": "0.5.0",
  "description": "JP Bids MCP provides Japan government procurement bid search through the Model Context Protocol.",
  "type": "module",
  "license": "Apache-2.0",
  "mcpName": "io.github.sugukurukabe/jp-bids",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    ".": {
      "types": "./dist/mcp.d.ts",
      "import": "./dist/mcp.js"
    },
    "./api": {
      "types": "./dist/api/kkj-client.d.ts",
      "import": "./dist/api/kkj-client.js"
    },
    "./types": {
      "types": "./dist/domain/bid.d.ts",
      "import": "./dist/domain/bid.js"
    }
  },
  "sideEffects": false,
  "packageManager": "npm@11.6.2",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "procurement",
    "japan",
    "government",
    "bids",
    "kkj",
    "cloud-run"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sugukurukabe/koko-call-mcp.git"
  },
  "homepage": "https://github.com/sugukurukabe/koko-call-mcp",
  "bugs": {
    "url": "https://github.com/sugukurukabe/koko-call-mcp/issues"
  },
  "bin": {
    "jp-bids-export": "dist/export-bids.js",
    "jp-bids-mcp": "dist/server.js",
    "jp-bids-slack-briefing": "dist/slack-briefing.js"
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "README.ja.md",
    "README.id.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "CITATION.cff",
    "server.json",
    "public/.well-known/agents.json"
  ],
  "engines": {
    "node": ">=20 <25"
  },
  "scripts": {
    "build": "npm run build:server && npm run typecheck:ui && npm run build:ui",
    "build:server": "tsc -p tsconfig.json && chmod +x dist/server.js dist/slack-briefing.js dist/export-bids.js",
    "build:ui": "vite build",
    "typecheck:ui": "tsc -p tsconfig.app.json",
    "dev": "tsx src/server.ts",
    "dev:http": "tsx src/server.ts --http",
    "start": "node dist/server.js",
    "start:http": "node dist/server.js --http",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:contract": "vitest run tests/contract.test.ts",
    "bench": "tsx benchmarks/kkj.bench.ts",
    "mutation": "stryker run",
    "docs:api": "typedoc",
    "api:health": "tsx scripts/api-health-check.ts",
    "remote:health": "tsx scripts/remote-health-check.ts",
    "remote:mcp": "tsx scripts/remote-mcp-check.ts",
    "remote:domain": "tsx scripts/remote-domain-status.ts",
    "export:bids": "tsx src/export-bids.ts",
    "slack:briefing": "tsx scripts/slack-briefing.ts",
    "registry:validate": "tsx scripts/registry-validate.ts",
    "build:repro": "tsx scripts/reproducible-build.ts",
    "docs:check": "npm run docs:api && git diff --exit-code docs/api",
    "release:gate": "tsx scripts/release-gate.ts",
    "prepublishOnly": "npm run release:gate",
    "check": "npm run lint && npm run build && npm run test",
    "sbom": "cyclonedx-npm --output-file bom.json",
    "publish:dry-run": "npm publish --dry-run --access public --ignore-scripts"
  },
  "dependencies": {
    "@google/genai": "^1.51.0",
    "@modelcontextprotocol/ext-apps": "^1.7.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.7.2",
    "lru-cache": "^11.3.5",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "ajv-formats-draft2019": "^1.6.1",
    "fast-check": "^4.7.0",
    "libxmljs2": "^0.37.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "supertest": "^7.2.2",
    "tinybench": "^6.0.1",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.5"
  }
}
