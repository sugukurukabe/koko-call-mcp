{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "declaration": false,
    "emitDeclarationOnly": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "rootDir": "."
  },
  "include": ["src/apps/**/*.tsx", "src/apps/**/*.d.ts"],
  "exclude": ["node_modules", "dist", "tests"]
}
