PORT=
HTTP_HOST=
ALLOWED_ORIGINS=
# Pro APIキー（カンマ区切り）。設定するとFree/Pro tierが有効になる
# Pro API keys (comma-separated). Enables Free/Pro tier separation when set
# Kunci API Pro (dipisahkan koma). Mengaktifkan pemisahan tier Free/Pro jika diatur
JP_BIDS_PRO_API_KEYS=
JP_BIDS_RATE_LIMIT_PER_SECOND=
# Stripe課金設定 / Stripe billing configuration / Konfigurasi penagihan Stripe
# STRIPE_SECRET_KEY: Stripe Secretキー（sk_live_xxx / sk_test_xxx）
STRIPE_SECRET_KEY=
# STRIPE_DEFAULT_CUSTOMER_ID: デフォルトのStripe顧客ID（cus_xxx）。MVP段階の単一テナント用
# Default Stripe customer ID (cus_xxx). For single-tenant MVP stage
# ID pelanggan Stripe default (cus_xxx). Untuk tahap MVP single-tenant
STRIPE_DEFAULT_CUSTOMER_ID=
