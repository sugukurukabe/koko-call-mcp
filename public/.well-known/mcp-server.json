{
  "name": "JP Bids MCP",
  "version": "0.7.0",
  "description": "日本の官公需入札情報をMCPで検索・AI分析。Japan government procurement bid search and AI analysis through MCP.",
  "homepage": "https://mcp.bid-jp.com",
  "repository": "https://github.com/sugukurukabe/koko-call-mcp",
  "license": "Apache-2.0",
  "privacy_policy": "https://mcp.bid-jp.com/privacy",
  "terms_of_service": "https://mcp.bid-jp.com/terms",
  "endpoints": {
    "mcp": "https://mcp.bid-jp.com/mcp"
  },
  "authentication": {
    "type": "oauth2",
    "authorization_servers": ["https://mcp.bid-jp.com"],
    "dynamic_client_registration_supported": true,
    "pkce_methods": ["S256"]
  },
  "capabilities": {
    "tools": {
      "listChanged": false
    },
    "resources": {
      "listChanged": false,
      "subscribe": false
    },
    "prompts": {
      "listChanged": false
    },
    "completions": {},
    "logging": {}
  },
  "transports": ["stdio", "streamable-http"],
  "data_sources": [
    {
      "name": "中小企業庁 官公需情報ポータルサイト 検索API",
      "url": "https://www.kkj.go.jp/",
      "license_url": "https://www.kkj.go.jp/s/help/notes/"
    }
  ]
}
